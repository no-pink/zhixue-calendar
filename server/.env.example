# ========================================
# 智学日程 — 环境变量配置
# ========================================
# 复制本文件为 .env 后修改
# cp server/.env.example server/.env

# --- 服务端口 ---
PORT=3001

# --- 运行环境 (development / production) ---
NODE_ENV=development

# --- 日志级别: trace, debug, info, warn, error, fatal ---
LOG_LEVEL=info

# --- JWT 密钥（生产环境必须设置为强随机字符串）---
# 生成方式: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# --- JWT 过期时间 ---
JWT_EXPIRES_IN=7d

# --- 数据库路径（默认 server/data.db）---
DB_PATH=

# --- 上传目录（默认 server/uploads）---
UPLOAD_DIR=

# --- 最大上传文件大小（字节，默认 10MB）---
MAX_FILE_SIZE=10485760

# --- 允许的 MIME 类型（逗号分隔）---
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,application/zip,text/plain

# --- CORS 允许的源 ---
# 开发环境: * (允许所有)
# 生产环境: 必须设为具体域名，如 https://your-domain.com
CORS_ORIGIN=*

# --- 速率限制 ---
# 窗口(ms) / 最大请求数
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# --- 认证接口速率限制：窗口内最大尝试次数 ---
RATE_LIMIT_AUTH_MAX=10
