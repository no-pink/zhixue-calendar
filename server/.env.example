# 服务端口
PORT=3001

# 日志级别: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# JWT 密钥（生产环境必须设置）
JWT_SECRET=

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 数据库路径（默认 server/data.db）
DB_PATH=

# 上传目录（默认 server/uploads）
UPLOAD_DIR=

# 最大上传文件大小（字节，默认 10MB）
MAX_FILE_SIZE=10485760

# 允许的 MIME 类型（逗号分隔）
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp

# CORS 允许的源（默认 *）
CORS_ORIGIN=*

# 全局速率限制：窗口(ms) / 最大请求数
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# 认证接口速率限制：窗口内最大尝试次数
RATE_LIMIT_AUTH_MAX=10
